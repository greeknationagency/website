---
import Layout from '../layouts/Layout.astro';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<Layout title="Contact Us">
	<div class="container mx-auto px-4 py-16 max-w-5xl">
		<div class="mb-12 text-center md:text-left">
			<h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
			<p class="text-zinc-400 text-lg max-w-2xl">
				Have a question, or want to become a Greek Nation Ambassador at your school? Reach out below.
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-12">
			<!-- General Contact Form -->
			<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8">
				<h2 class="text-2xl font-bold mb-6">Get in Touch</h2>
				<form class="space-y-4">
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Name</label>
						<Input type="text" placeholder="Your Name" className="bg-zinc-950 border-zinc-800" />
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Email</label>
						<Input type="email" placeholder="you@example.com" className="bg-zinc-950 border-zinc-800" />
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Message</label>
						<textarea class="flex min-h-[120px] w-full rounded-md border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm placeholder:text-zinc-400 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50" placeholder="How can we help?"></textarea>
					</div>
					<Button type="button" className="w-full">Send Message</Button>
				</form>
			</div>

			<!-- Ambassador Application -->
			<div class="bg-zinc-950 border border-zinc-800 rounded-xl p-8 relative overflow-hidden">
				<!-- Decorative background -->
				<div class="absolute inset-0 bg-gradient-to-br from-zinc-800/20 to-transparent pointer-events-none"></div>
				
				<div class="relative z-10">
					<h2 class="text-2xl font-bold mb-2">Become an Ambassador</h2>
					<p class="text-zinc-400 text-sm mb-6">Join the Greek Nation team at your university.</p>
					
					<form class="space-y-4">
						<div>
							<label class="block text-sm font-medium text-zinc-300 mb-1">School / Chapter</label>
							<Input type="text" placeholder="e.g. UCLA / Sigma Chi" className="bg-zinc-900 border-zinc-700" />
						</div>
						<div>
							<label class="block text-sm font-medium text-zinc-300 mb-1">Role / Title</label>
							<select class="flex h-9 w-full items-center justify-between whitespace-nowrap rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm shadow-sm ring-offset-background placeholder:text-muted-foreground focus:outline-none focus:ring-1 focus:ring-ring disabled:cursor-not-allowed disabled:opacity-50 [&>span]:line-clamp-1 text-white">
								<option value="" disabled selected>Select your role...</option>
								<option value="president">President</option>
								<option value="vp">Vice President</option>
								<option value="treasurer">Treasurer</option>
								<option value="social">Social Chair</option>
								<option value="asst_social">Assistant Social Chair</option>
							</select>
						</div>
						<div>
							<label class="block text-sm font-medium text-zinc-300 mb-1">Why do you want to be an Ambassador?</label>
							<textarea class="flex min-h-[80px] w-full rounded-md border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm placeholder:text-zinc-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring text-white" placeholder="Brief note..."></textarea>
						</div>
						<Button type="button" variant="secondary" className="w-full">Apply Now</Button>
					</form>
				</div>
			</div>
		</div>
	</div>
</Layout>
