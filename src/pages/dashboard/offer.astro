---
import Layout from '../../layouts/Layout.astro';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<Layout title="Submit an Offer">
	<div class="container mx-auto px-4 py-12 max-w-3xl">
		<div class="mb-8">
			<h1 class="text-3xl font-bold mb-2">Submit an Offer</h1>
			<p class="text-zinc-400">Directly book an artist for your next event.</p>
		</div>

		<div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-6 md:p-8">
			<form class="space-y-6">
				<!-- Pre-filled member info (read-only style or hidden in real app) -->
				<div class="bg-zinc-950/50 p-4 rounded-lg border border-zinc-800/50 mb-6">
					<p class="text-sm text-zinc-400">Submitting on behalf of:</p>
					<p class="font-medium text-white">John Doe • Sigma Chi, University of Florida</p>
				</div>

				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Artist</label>
						<!-- In a real app this would be a searchable select or pre-filled from URL param -->
						<Input type="text" placeholder="Select or type artist name" className="bg-zinc-950 border-zinc-800" />
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Event Date</label>
						<Input type="date" className="bg-zinc-950 border-zinc-800 text-white" />
					</div>
				</div>

				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Location / Venue</label>
						<Input type="text" placeholder="e.g. Chapter House, Downtown Venue" className="bg-zinc-950 border-zinc-800" />
					</div>
					<div>
						<label class="block text-sm font-medium text-zinc-300 mb-1">Offer Amount ($)</label>
						<Input type="number" placeholder="Enter budget" className="bg-zinc-950 border-zinc-800" />
					</div>
				</div>

				<div>
					<label class="block text-sm font-medium text-zinc-300 mb-1">Event Details & Notes</label>
					<textarea class="flex min-h-[120px] w-full rounded-md border border-zinc-800 bg-zinc-950 px-3 py-2 text-sm placeholder:text-zinc-500 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring text-white" placeholder="Describe the event, expected attendance, production provided, etc."></textarea>
				</div>

				<div class="pt-4">
					<Button type="button" className="w-full h-12 text-base">Submit Offer to Artist</Button>
					<p class="text-xs text-zinc-500 text-center mt-3">Your offer will be sent directly to the artist's management team.</p>
				</div>
			</form>
		</div>
	</div>
</Layout>
