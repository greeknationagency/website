---
import Layout from '../../layouts/Layout.astro';
import { Input } from '@/components/ui/input';
import { Button } from '@/components/ui/button';
---

<Layout title="Member Connect">
	<div class="container mx-auto px-4 py-12 max-w-6xl">
		<div class="mb-10">
			<h1 class="text-3xl font-bold mb-2">Member Connect</h1>
			<p class="text-zinc-400">Connect with members at other schools. Share ideas, coordinate events, and grow the network.</p>
		</div>

		<div class="flex flex-col md:flex-row gap-4 mb-8">
			<div class="w-full md:max-w-md">
				<Input type="search" placeholder="Search by school, chapter, or name..." className="bg-zinc-900 border-zinc-800" />
			</div>
			<Button variant="secondary" className="bg-zinc-800 hover:bg-zinc-700 text-white border border-zinc-700">
				Filter by School
			</Button>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{[1, 2, 3, 4, 5, 6].map((i) => (
				<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 flex flex-col hover:border-zinc-700 transition-colors">
					<div class="flex items-start gap-4 mb-4">
						<div class="w-12 h-12 rounded-full bg-zinc-800 flex-shrink-0"></div>
						<div>
							<h3 class="font-bold text-white text-lg">Alex Member {i}</h3>
							<p class="text-sm text-zinc-400">Social Chair</p>
						</div>
					</div>
					
					<div class="mb-6 space-y-1">
						<p class="text-sm text-zinc-300 font-medium">Sigma Chi</p>
						<p class="text-sm text-zinc-500">University of Florida</p>
					</div>

					<div class="mt-auto pt-4 border-t border-zinc-800/50">
						<Button variant="outline" className="w-full border-zinc-700 text-zinc-300 hover:bg-zinc-800 hover:text-white">
							Connect
						</Button>
					</div>
				</div>
			))}
		</div>
	</div>
</Layout>
