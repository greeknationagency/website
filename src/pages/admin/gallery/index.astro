---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../db';
import { media } from '../../../db/schema';
import { desc } from 'drizzle-orm';
import { Button } from '@/components/ui/button';

const allMedia = await db.select().from(media).orderBy(desc(media.createdAt));
---

<Layout title="Admin - Manage Gallery">
	<div class="container mx-auto px-4 py-12 min-h-[80vh]">
		<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
			<div>
				<h1 class="text-3xl font-bold text-white mb-2">Manage Gallery</h1>
				<p class="text-zinc-400 text-sm">Upload photos and videos for the public gallery.</p>
			</div>
			<a href="/admin/events">
				<Button variant="outline">&larr; Back to Events</Button>
			</a>
		</div>

		<!-- Drag and Drop Zone -->
		<div class="mb-12">
			<div 
				id="drop-zone"
				class="border-2 border-dashed border-zinc-700 bg-zinc-900/50 hover:bg-zinc-800/50 transition-colors rounded-xl p-12 text-center cursor-pointer relative"
			>
				<input type="file" id="file-input" multiple accept="image/*,video/*" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
				<div class="pointer-events-none flex flex-col items-center">
					<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-upload-cloud text-zinc-500 mb-4"><path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M12 12v9"/><path d="m16 16-4-4-4 4"/></svg>
					<h3 class="text-lg font-medium text-zinc-200 mb-1">Click or drag & drop files here</h3>
					<p class="text-sm text-zinc-500">Supports images and videos (MP4, WEBM, Quicktime)</p>
				</div>
			</div>
			
			<div id="upload-progress" class="hidden mt-6 bg-zinc-900 border border-zinc-800 rounded-lg p-4">
				<div class="flex justify-between text-sm mb-2">
					<span class="text-zinc-300 font-medium">Uploading...</span>
					<span id="progress-text" class="text-zinc-500">0%</span>
				</div>
				<div class="w-full bg-zinc-800 rounded-full h-2">
					<div id="progress-bar" class="bg-amber-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
				</div>
			</div>
		</div>

		<!-- Media List -->
		<div>
			<h2 class="text-xl font-bold text-white mb-6">Current Media</h2>
			<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-4">
				{allMedia.map((item) => (
					<div class="bg-zinc-900 border border-zinc-800 rounded-lg overflow-hidden group relative">
						<div class="aspect-square bg-zinc-950 relative">
							{item.type === 'video' ? (
								<video src={item.url} class="w-full h-full object-cover opacity-80" muted preload="metadata" />
							) : (
								<img src={item.url} alt={item.title || 'Media'} class="w-full h-full object-cover opacity-80" />
							)}
							{item.type === 'video' && (
								<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
									<div class="bg-black/50 rounded-full p-2">
										<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play text-white fill-white"><polygon points="6 3 20 12 6 21 6 3"/></svg>
									</div>
								</div>
							)}
						</div>
						<div class="p-3 flex justify-between items-center absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/90 to-transparent pt-8 opacity-0 group-hover:opacity-100 transition-opacity">
							<span class="text-xs font-medium text-zinc-300 capitalize">{item.type}</span>
							<button data-id={item.id} class="delete-btn text-xs font-medium text-red-500 hover:text-red-400 bg-black/50 px-2 py-1 rounded">Delete</button>
						</div>
					</div>
				))}
				
				{allMedia.length === 0 && (
					<div class="col-span-full py-12 text-center text-zinc-500 bg-zinc-900/50 rounded-xl border border-zinc-800 border-dashed">
						No media found. Upload some above!
					</div>
				)}
			</div>
		</div>
	</div>

	<script>
		import { upload } from '@vercel/blob/client';

		// Upload Logic
		const fileInput = document.getElementById('file-input') as HTMLInputElement;
		const dropZone = document.getElementById('drop-zone');
		const uploadProgress = document.getElementById('upload-progress');
		const progressBar = document.getElementById('progress-bar');
		const progressText = document.getElementById('progress-text');

		async function handleFiles(files: FileList | File[]) {
			if (!files || files.length === 0) return;
			
			uploadProgress?.classList.remove('hidden');
			let successCount = 0;

			for (let i = 0; i < files.length; i++) {
				const file = files[i];
				const type = file.type.startsWith('video/') ? 'video' : 'photo';
				
				try {
					if (progressText && progressBar) {
						progressText.textContent = `Uploading file ${i + 1} of ${files.length}...`;
						progressBar.style.width = '10%';
					}

					// 1. Upload to Vercel Blob (Client Upload)
					const newBlob = await upload(file.name, file, {
						access: 'public',
						handleUploadUrl: '/api/upload/client',
						onUploadProgress: (e) => {
							if (progressBar) {
								progressBar.style.width = `${e.percentage}%`;
							}
						}
					});

					// 2. Save to our database
					const res = await fetch('/api/admin/media', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({
							url: newBlob.url,
							type: type,
							title: file.name
						})
					});

					if (res.ok) {
						successCount++;
					} else {
						console.error('Failed to save to DB:', await res.json());
					}
				} catch (err) {
					console.error('Upload failed:', err);
					alert(`Failed to upload ${file.name}. Ensure you have configured BLOB_READ_WRITE_TOKEN and the file is an image/video.`);
				}
			}

			if (progressText && progressBar) {
				progressText.textContent = 'Done!';
				progressBar.style.width = '100%';
			}

			if (successCount > 0) {
				window.location.reload();
			} else {
				setTimeout(() => uploadProgress?.classList.add('hidden'), 2000);
			}
		}

		// Event Listeners for File Input & Drag/Drop
		fileInput?.addEventListener('change', (e) => {
			const target = e.target as HTMLInputElement;
			if (target.files) handleFiles(target.files);
		});

		dropZone?.addEventListener('dragover', (e) => {
			e.preventDefault();
			dropZone.classList.add('border-amber-500');
		});

		dropZone?.addEventListener('dragleave', (e) => {
			e.preventDefault();
			dropZone.classList.remove('border-amber-500');
		});

		dropZone?.addEventListener('drop', (e) => {
			e.preventDefault();
			dropZone.classList.remove('border-amber-500');
			if (e.dataTransfer?.files) {
				handleFiles(e.dataTransfer.files);
			}
		});

		// Delete Logic
		const deleteBtns = document.querySelectorAll('.delete-btn');
		deleteBtns.forEach(btn => {
			btn.addEventListener('click', async (e) => {
				const target = e.target as HTMLButtonElement;
				const id = target.getAttribute('data-id');
				
				if (!id || !confirm('Are you sure you want to delete this file? This cannot be undone.')) return;
				
				target.disabled = true;
				target.textContent = '...';
				
				try {
					const res = await fetch('/api/admin/media', {
						method: 'DELETE',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ id })
					});
					
					if (res.ok) {
						window.location.reload();
					} else {
						alert('Failed to delete media');
						target.disabled = false;
						target.textContent = 'Delete';
					}
				} catch (err) {
					console.error(err);
					alert('Error deleting media');
					target.disabled = false;
					target.textContent = 'Delete';
				}
			});
		});
	</script>
</Layout>
