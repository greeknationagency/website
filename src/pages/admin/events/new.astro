---
import Layout from '../../../layouts/Layout.astro';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
---

<Layout title="Admin - Create Event">
	<div class="container mx-auto px-4 py-12 min-h-[80vh] max-w-2xl">
		<div class="mb-8">
			<a href="/admin/events" class="text-sm font-medium text-zinc-500 hover:text-white transition-colors mb-4 inline-block">&larr; Back to Events</a>
			<h1 class="text-3xl font-bold text-white mb-2">Create New Event</h1>
			<p class="text-zinc-400 text-sm">Add a new event to the Greek Nation calendar.</p>
		</div>

		<div class="bg-zinc-900 border border-zinc-800 rounded-xl p-8">
			<form class="space-y-6">
				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Event Title <span class="text-red-500">*</span></label>
					<Input type="text" name="title" required placeholder="Greek Week 2027 Concert" className="bg-zinc-950 border-zinc-800" />
				</div>
				
				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Date & Time <span class="text-red-500">*</span></label>
					<Input type="datetime-local" name="eventDate" required className="bg-zinc-950 border-zinc-800" />
				</div>

				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Location</label>
					<Input type="text" name="location" placeholder="Main Campus Arena" className="bg-zinc-950 border-zinc-800" />
				</div>

				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Description</label>
					<Textarea name="description" placeholder="Join us for the biggest event of the year..." className="bg-zinc-950 border-zinc-800 min-h-[120px]" />
				</div>

				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Ticket Link</label>
					<Input type="url" name="ticketLink" placeholder="https://..." className="bg-zinc-950 border-zinc-800" />
				</div>

				<!-- Will add Blob upload here later -->
				<div class="space-y-2">
					<label class="block text-sm font-medium text-zinc-300">Image URL (Optional)</label>
					<Input type="url" name="imageUrl" placeholder="https://..." className="bg-zinc-950 border-zinc-800" />
				</div>

				<div class="pt-4 flex items-center justify-end space-x-4 border-t border-zinc-800 mt-8 pt-8">
					<a href="/admin/events" class="text-sm font-medium text-zinc-400 hover:text-white">Cancel</a>
					<Button type="submit">Publish Event</Button>
				</div>
			</form>
			<p id="error-message" class="text-red-500 text-sm mt-4 text-center hidden"></p>
		</div>
	</div>

	<script>
		const form = document.querySelector('form');
		const errorMessage = document.getElementById('error-message');

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			errorMessage?.classList.add('hidden');

			const formData = new FormData(form);
			
			try {
				const res = await fetch('/api/admin/events', {
					method: 'POST',
					body: formData
				});
				
				const data = await res.json();
				
				if (res.ok) {
					window.location.href = '/admin/events';
				} else {
					if (errorMessage) {
						errorMessage.textContent = data.error || 'An error occurred';
						errorMessage.classList.remove('hidden');
					}
				}
			} catch (err) {
				console.error(err);
				if (errorMessage) {
					errorMessage.textContent = 'An unexpected error occurred';
					errorMessage.classList.remove('hidden');
				}
			}
		});
	</script>
</Layout>
